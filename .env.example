# ============================================================
# vtracking_trip_system_bundle — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# .env is loaded automatically if python-dotenv is installed:
#   pip install python-dotenv
#
# Shell env vars always take precedence over .env.
# ============================================================

# ------------------------------------------------------------
# Google Maps API Key (required for all Google API calls)
# Without this key the system falls back to OSRM + straight-line.
# ------------------------------------------------------------
GOOGLE_MAPS_API_KEY="..."

# ------------------------------------------------------------
# Provider selection
# ------------------------------------------------------------

# GPS map-matching provider.
# Values: osrm (default) | google_roads
# google_roads requires GOOGLE_MAPS_API_KEY.
MAP_MATCH_PROVIDER=osrm

# Route corridor building provider.
# Values: google_directions (default) | google_routes | osrm
# Both google_* values require GOOGLE_MAPS_API_KEY.
ROUTE_PROVIDER=google_directions

# ------------------------------------------------------------
# Depot coordinate (trip start and end point)
# ------------------------------------------------------------

# Latitude and longitude of the company depot.
# Leg 0 always departs from here; the return leg always ends here.
# Default: 10.802417, 106.501501
DEPOT_LAT=10.802417
DEPOT_LNG=106.501501

# ------------------------------------------------------------
# Corridor geometry
# ------------------------------------------------------------

# Lateral buffer around each route polyline in metres.
# A GPS point is "inside the corridor" if within this distance
# of any feasible route polyline. Default: 200.0
CORRIDOR_BUFFER_M=200.0

# ------------------------------------------------------------
# Corridor feature flags
# ------------------------------------------------------------

# Add a return-to-origin (depot) leg when building trip corridors.
# Default: true — every delivery loop departs from and returns to the depot.
# Set to false only for one-way trips where the vehicle does not return.
# NOTE: expected_distance_km and detour_ratio always use delivery scope only,
# regardless of this setting.
ENABLE_RETURN_LEG=true

# Request a toll-free route alternative when building corridors.
# Default: false
ENABLE_AVOID_TOLLS_ROUTE=false

# Request a no-highway route alternative when building corridors.
# Default: false
ENABLE_AVOID_HIGHWAYS_ROUTE=false

# Request a no-ferry route alternative when building corridors.
# Default: false
ENABLE_AVOID_FERRIES_ROUTE=false
